[{"id":4,"nom":"Auberge de la Pendjari","type_fr":"Auberge","type_en":"Inn","localite":"Tangui\u00e9ta","quartier":"Entr\u00e9e du Parc","prix_nuit":30000,"devise":"FCFA","description_fr":"L'adresse id\u00e9ale pour les aventuriers en partance pour le safari. Chambres climatis\u00e9es et conseils pr\u00e9cieux de pisteurs.","description_en":"The perfect place for adventurers setting off on safari. Air-conditioned rooms and valuable tips from local trackers.","photo":"auberge_pendjari.jpg","email_contact":"reservation@pendjari-auberge.bj"},{"id":5,"nom":"Chez Val\u00e9rie - \u00c9colodge","type_fr":"Maison d'h\u00f4tes","type_en":"Guest house","localite":"Ganvi\u00e9","quartier":"Lac Nokou\u00e9","prix_nuit":20000,"devise":"FCFA","description_fr":"Vivez l'exp\u00e9rience authentique d'une nuit sur pilotis. Bungalows traditionnels tout confort avec terrasse priv\u00e9e face au coucher du soleil.","description_en":"Experience the authentic feel of a night on stilts. Comfortable traditional bungalows with private terrace facing the sunset.","photo":"ecolodge_ganvie.jpg","email_contact":"valerie.ganvie@yahoo.fr"},{"id":2,"nom":"Golden Tulip Le Diplomate","type_fr":"H\u00f4tel","type_en":"Hotel","localite":"Cotonou","quartier":"Haie Vive","prix_nuit":95000,"devise":"FCFA","description_fr":"H\u00f4tel haut de gamme situ\u00e9 dans le quartier r\u00e9sidentiel le plus dynamique de Cotonou, id\u00e9al pour les voyages d'affaires et de loisirs.","description_en":"Premium hotel located in the most dynamic residential area of Cotonou, ideal for business and leisure travel.","photo":"golden_tulip.jpg","email_contact":"info@goldentulipcotonou.com"},{"id":1,"nom":"H\u00f4tel de la Plage","type_fr":"H\u00f4tel","type_en":"Hotel","localite":"Grand-Popo","quartier":"Front de mer","prix_nuit":45000,"devise":"FCFA","description_fr":"Un havre de paix face \u00e0 l'Oc\u00e9an Atlantique proposant des bungalows confortables, une piscine et un restaurant de sp\u00e9cialit\u00e9s locales.","description_en":"A peaceful haven facing the Atlantic Ocean offering comfortable bungalows, a swimming pool, and a restaurant serving local specialties.","photo":"hotel_plage_popo.jpg","email_contact":"contact@hotelplagepopo.com"},{"id":3,"nom":"La Casa de Ouidah","type_fr":"Maison d'h\u00f4tes","type_en":"Guest house","localite":"Ouidah","quartier":"Ahouandjigo","prix_nuit":25000,"devise":"FCFA","description_fr":"Une maison d'h\u00f4tes de charme au c\u0153ur du quartier historique, mariant architecture afro-br\u00e9silienne et confort moderne.","description_en":"A charming guest house in the heart of the historic district, blending Afro-Brazilian architecture with modern comfort.","photo":"la_casa_ouidah.jpg","email_contact":"lacasaouidah@gmail.com"}]