[{"id":1,"nom_fr":"Cit\u00e9 lacustre de Ganvi\u00e9","nom_en":"Ganvi\u00e9 Stilt Village","region_fr":"Atlantique (Lac Nokou\u00e9)","region_en":"Atlantique (Lake Nokou\u00e9)","categorie":"Culture","description_courte_fr":"Surnomm\u00e9e la Venise de l'Afrique, cette cit\u00e9 sur pilotis abrite plus de 30 000 habitants.","description_courte_en":"Known as the Venice of Africa, this stilt village is home to over 30,000 residents.","photo_principale":"ganvie.jpg","latitude":"6.4678220","longitude":"2.4172580"},{"id":2,"nom_fr":"Palais Royaux d'Abomey","nom_en":"Royal Palaces of Abomey","region_fr":"Zou","region_en":"Zou","categorie":"Culture","description_courte_fr":"Inscrits au patrimoine mondial de l'UNESCO, ils racontent l'\u00e9pop\u00e9e du puissant royaume du Dahomey.","description_courte_en":"A UNESCO World Heritage site, recounting the epic story of the powerful Dahomey Kingdom.","photo_principale":"abomey.jpg","latitude":"7.1856930","longitude":"1.9918230"},{"id":3,"nom_fr":"Route des Esclaves \u00e0 Ouidah","nom_en":"Slave Route in Ouidah","region_fr":"Atlantique","region_en":"Atlantique","categorie":"Culture","description_courte_fr":"Un parcours m\u00e9moriel historique retra\u00e7ant le dernier chemin des captifs vers les navires n\u00e9griers.","description_courte_en":"A historical memorial path tracing the final journey of captives to the slave ships.","photo_principale":"route_esclaves.jpg","latitude":"6.3621450","longitude":"2.0831200"}]