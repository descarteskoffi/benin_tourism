[{"id":10,"nom_fr":"Centre Songha\u00ef \u00e0 Porto-Novo","nom_en":"Songhai Center in Porto-Novo","region_fr":"Ou\u00e9m\u00e9","region_en":"Oueme","categorie":"Nature","description_courte_fr":"Un centre d'innovation agro-\u00e9cologique de r\u00e9f\u00e9rence mondiale bas\u00e9 sur le principe du \"z\u00e9ro d\u00e9chet\".","description_courte_en":"A world-renowned agro-ecological innovation center based on the \"zero waste\" principle.","photo_principale":"songhai.jpg","latitude":"6.5053000","longitude":"2.6184000"},{"id":1,"nom_fr":"Cit\u00e9 lacustre de Ganvi\u00e9","nom_en":"Ganvi\u00e9 Stilt Village","region_fr":"Atlantique (Lac Nokou\u00e9)","region_en":"Atlantique (Lake Nokou\u00e9)","categorie":"Culture","description_courte_fr":"Surnomm\u00e9e la Venise de l'Afrique, cette cit\u00e9 sur pilotis abrite plus de 30 000 habitants.","description_courte_en":"Known as the Venice of Africa, this stilt village is home to over 30,000 residents.","photo_principale":"ganvie.jpg","latitude":"6.4678220","longitude":"2.4172580"},{"id":8,"nom_fr":"Collines de Dassa-Zoum\u00e8","nom_en":"Hills of Dassa-Zoume","region_fr":"Collines","region_en":"Collines","categorie":"Spiritualit\u00e9","description_courte_fr":"La ville aux 41 collines, haut lieu de p\u00e8lerinage catholique et de myst\u00e8res l\u00e9gendaires.","description_courte_en":"The city of 41 hills, a major site for Catholic pilgrimage and legendary mysteries.","photo_principale":"dassa.jpg","latitude":"7.7456720","longitude":"2.1834920"},{"id":7,"nom_fr":"Les Chutes de Kota","nom_en":"Kota Waterfalls","region_fr":"Atacora","region_en":"Atacora","categorie":"Nature","description_courte_fr":"De magnifiques cascades d'eau nich\u00e9es au c\u0153ur d'une for\u00eat galerie luxuriante pr\u00e8s de Natitingou.","description_courte_en":"Beautiful waterfalls nestled in the heart of a lush gallery forest near Natitingou.","photo_principale":"kota.jpg","latitude":"10.2098230","longitude":"1.4421940"},{"id":2,"nom_fr":"Palais Royaux d'Abomey","nom_en":"Royal Palaces of Abomey","region_fr":"Zou","region_en":"Zou","categorie":"Culture","description_courte_fr":"Inscrits au patrimoine mondial de l'UNESCO, ils racontent l'\u00e9pop\u00e9e du puissant royaume du Dahomey.","description_courte_en":"A UNESCO World Heritage site, recounting the epic story of the powerful Dahomey Kingdom.","photo_principale":"abomey.jpg","latitude":"7.1856930","longitude":"1.9918230"},{"id":4,"nom_fr":"Parc National de la Pendjari","nom_en":"Pendjari National Park","region_fr":"Atacora","region_en":"Atacora","categorie":"Nature","description_courte_fr":"L'une des plus belles r\u00e9serves de faune d'Afrique de l'Ouest, abritant lions, \u00e9l\u00e9phants et gu\u00e9pards.","description_courte_en":"One of the finest wildlife reserves in West Africa, home to lions, elephants, and cheetahs.","photo_principale":"pendjari.jpg","latitude":"11.2384720","longitude":"1.5478920"}]